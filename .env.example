# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Telegram ID администраторов (через запятую)
ADMIN_IDS=123456789,987654321

# Docker-контейнер AmneziaWG
DOCKER_CONTAINER=amnezia-awg2

# Путь к серверному конфигу внутри контейнера
AWG_CONFIG_PATH=/opt/amnezia/awg/awg0.conf

# Публичный адрес сервера для клиентского конфига (IP или домен)
SERVER_ENDPOINT=your.server.ip

# UDP-порт AWG (если не указан — берётся из awg0.conf)
# AWG_PORT=51820

# DNS для клиентов
DNS_PRIMARY=1.1.1.1
DNS_SECONDARY=1.0.0.1

# Тип контейнера в vpn:// URI (amnezia-awg2 для AWG 2.0)
AWG_CONTAINER_TYPE=amnezia-awg2

# Название подключения в AmneziaVPN
VPN_DESCRIPTION=AWG Server

# MTU в vpn:// URI
AWG_MTU=1280

# Путь к SQLite базе
# Локально: ./data/bot.db
# В Docker: /app/data/bot.db (задаётся в docker-compose.yml)
DATABASE_PATH=./data/bot.db

# Уровень логов: DEBUG, INFO, WARNING (по умолчанию INFO)
# LOG_LEVEL=INFO

# Версия бота читается из файла VERSION в образе.
# BOT_VERSION — только запасной вариант, если VERSION нет (обычно не нужен).
# BOT_VERSION=1.0.0
